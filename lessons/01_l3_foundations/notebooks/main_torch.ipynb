    "## 2. Очистка текста регулярными выражениями\n",
    "\n",
    "Удаляем URL, `@упоминания`, `#хэштеги`, эмотиконы (`:D`, `:)`, `xD`),\n",
    "изолированные числа, спецсимволы и лишнюю пунктуацию, приводим к нижнему регистру."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "4712d87a",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "До:    @first_timee хоть я и школота, но поверь, у нас то же самое :D общество профилирующий предмет типа)\n",
      "После: хоть я и школота но поверь у нас то же самое общество профилирующий предмет типа\n"
     ]
    }
   ],
   "source": [
    "def clean_text(text):\n",
    "    text = html.unescape(str(text))\n",
    "    text = text.lower()\n",
    "    text = re.sub(r\"http\\S+|www\\.\\S+\", \" \", text)     # URL\n",
    "    text = re.sub(r\"@\\w+\", \" \", text)                  # @mentions\n",
    "    text = re.sub(r\"#\\w+\", \" \", text)                  # #hashtags\n",
    "    text = re.sub(r\"[:;xX]-?[)dpDP(]+\", \" \", text)      # эмотиконы :D :) :( xD\n",
    "    text = re.sub(r\"[^а-яёa-z0-9\\s]\", \" \", text)        # спецсимволы/пунктуация\n",
    "    text = re.sub(r\"\\b\\d+\\b\", \" \", text)                # изолированные числа\n",
    "    text = re.sub(r\"\\s+\", \" \", text).strip()\n",
    "    return text\n",
    "\n",
    "\n",
    "df[\"clean_text\"] = df[\"text\"].apply(clean_text)\n",
    "\n",
    "print(\"До:   \", df[\"text\"].iloc[0][:180])\n",
    "print(\"После:\", df[\"clean_text\"].iloc[0][:180])"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "191325ca",
   "metadata": {},
   "source": [
    "## 3. Нормализация текста (лемматизация pymorphy3)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "id": "cbc091da",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Очищено:         хоть я и школота но поверь у нас то же самое общество профилирующий предмет типа\n",
      "Лемматизировано: хоть я и школотый но поверь у мы то же самый общество профилировать предмет тип\n"
     ]
    }
   ],
   "source": [
    "morph = pymorphy3.MorphAnalyzer()\n",
    "\n",
    "\n",
    "def lemmatize(text):\n",
    "    return \" \".join(morph.parse(word)[0].normal_form for word in text.split())\n",
    "\n",
    "\n",
    "df[\"lemma_text\"] = df[\"clean_text\"].apply(lemmatize)\n",
    "\n",
    "print(\"Очищено:        \", df[\"clean_text\"].iloc[0][:180])\n",
    "print(\"Лемматизировано:\", df[\"lemma_text\"].iloc[0][:180])"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "638b0875",
   "metadata": {},
   "source": [
    "## 4. Train / test split"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "id": "3a758413",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Train: 181467, Test: 45367\n",
      "label\n",
