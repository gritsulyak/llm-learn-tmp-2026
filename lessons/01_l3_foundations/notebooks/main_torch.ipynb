     ]
    }
   ],
   "source": [
    "df_train, df_test = train_test_split(\n",
    "    df, test_size=0.2, random_state=42, stratify=df[\"label\"]\n",
    ")\n",
    "print(f\"Train: {len(df_train)}, Test: {len(df_test)}\")\n",
